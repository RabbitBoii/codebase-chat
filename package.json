{
  "name": "context-code-explainer",
  "displayName": "hello world",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:context-code-explainer.helloWorld"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-code-explainer.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "codebaseChat.index",
        "title": "Codebase Chat: Index Project"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codebase-chat-container",
          "title": "Codebase Chat",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codebase-chat-container": [
        {
          "type": "webview",
          "id": "codebaseChatView",
          "name": "Chat"
        }
      ]
    }
  },
  "configuration": {
    "title": "Codebase Chat",
    "properties": {
      "codebaseChat.openaiApiKey": {
        "type": "string",
        "default": "",
        "description": "Your OpenAI API key for embeddings and chat"
      },
      "codebaseChat.groqApiKey": {
        "type": "string",
        "default": "",
        "description": "Your Groq API key for LLM responses"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@langchain/community": "^1.1.27",
    "@langchain/openai": "^1.4.4",
    "@langchain/textsplitters": "^1.0.1",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "groq-sdk": "^1.1.2",
    "langchain": "^1.3.3"
  }
}
